{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$PLUGIN_ROOT/hooks/save-memory-stop.sh\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%PLUGIN_ROOT%\\hooks\\save-memory-stop.ps1\"",
            "timeout": 10,
            "statusMessage": "kensa-qa: checking memory checkpoint"
          }
        ]
      }
    ]
  }
}
